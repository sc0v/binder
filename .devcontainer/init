#!/bin/bash
set -e

if [ -f ".devcontainer/.env.local" ]; then
  echo "  .devcontainer/.env.local already exists, skipping"
  exit 0
fi

echo "Generating VAPID keys..."
ruby -e "
require 'openssl'
require 'base64'

key = OpenSSL::PKey::EC.generate('prime256v1')
private_key = Base64.urlsafe_encode64(key.private_key.to_s(2), padding: false)
public_key = Base64.urlsafe_encode64(key.public_key.to_octet_string(:uncompressed), padding: false)

File.write('.devcontainer/.env.local', \"VAPID_PUBLIC_KEY=\#{public_key}\nVAPID_PRIVATE_KEY=\#{private_key}\n\")
puts '  Generated .devcontainer/.env.local'
"
