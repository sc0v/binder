<% update_document_title(add: 'PPE Collection') %>
<% update_breadcrumbs(add: link_to('Applets', applets_path)) %>
<% update_breadcrumbs(add: 'PPE Collection') %>
<% nav(active: 'ppe_collection') %>

<div class="content">
  <div>
    <h1>Returns</h1>
    <%= form_tag ppe_collection_path, method: 'get' do %>
      <ol>
        <li>Use the barcode scannner to read the Hardhat</li>
        <li>
          <%= label_tag(:hardhat_barcode, 'Barcode') %>
          <%= text_field_tag(:hardhat_barcode, nil, autocomplete: :off, autofocus: true) %>
        </li>
        <li>Mark the condition of the Hardhat</li>

        <%= button_tag 'Good Condition',
                       name: 'status',
                       value: 'good condition',
                       class: 'btn' %>
        <%= button_tag 'Damaged', name: 'status', value: 'damaged', class: 'btn' %>
      </ol>
    <% end %>
  </div>
</div>
