<% update_document_title(add: 'Wristband Lookup') %>
<% update_breadcrumbs(add: link_to('Applets', applets_path)) %>
<% update_breadcrumbs(add: 'Wristband Lookup') %>
<% nav(active: 'wristband_lookup') %>

<div class="content">
  <div>
    <h1>Wristband Lookup</h1>
    <%= form_tag wristband_lookup_path, method: 'get' do %>
      <%= label_tag :participant_search, 'Scan or enter CMU ID' %>
      <%= text_field_tag :participant_search,
                         nil,
                         autocomplete: :off,
                         autofocus: true,
                         placeholder: 'Tap card or type Andrew ID...' %>
    <% end %>

    <% if @participant %>
      <h2><%= @participant.name %></h2>
      <% bands = @participant.wristbands %>
      <% if bands.present? %>
        <% if bands.include?(:red) %>
          <p class="invert red" style="padding: 1em;"
            >Red (Building org member)</p
          >
        <% end %>
        <% if bands.include?(:blue) %>
          <p class="invert blue" style="padding: 1em;"
            >Blue (Non-building org member)</p
          >
        <% end %>
        <% if bands.include?(:green) %>
          <p class="invert green" style="padding: 1em;"
            >Green (Scissor Lift Certified)</p
          >
        <% end %>
        <% if bands.include?(:yellow) %>
          <p class="gold" style="padding: 1em;">Yellow (Alumni)</p>
        <% end %>
      <% elsif @participant.signed_waiver? %>
        <p>No wristbands assigned.</p>
      <% else %>
        <p><%= @participant.name %> has not signed the waiver yet.</p>
      <% end %>
    <% end %>
  </div>
</div>
