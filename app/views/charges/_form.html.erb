<p>
  When adding a charge, please ensure that you add a detailed description. This
  allows us to defend the charge if and when an org protests it. Information to
  include would be things like who, what, where, when, and why. If Dan wants to
  add a charge to TriDelt for blowing their breaker for the second time, the
  coordinator on duty should add a charge to Delta Delta Delta for a blown
  breaker for $25 with the description "TriDelt plugged in too many space
  heaters Wednesday night because they got cold, even though they were warned
  against this." by Dan Miele to TriDelt's booth chair. <br />
  <br />
</p>
<%= form_with model: @charge, html: { class: 'form-horizontal' } do |f| %>
  <div class="form-inputs">
    <%= f.label 'Organization' %>
    <%= f.collection_select(
          :organization_id,
          Organization.ordered_by_name,
          :id,
          :name,
          {},
          id: 'organization-select'
        ) %>
    <div class="row" style="display:flex;">
      <div>
        <%= f.label 'Charge Type' %>
        <%= f.collection_select :charge_type_id,
                                ChargeType.ordered_by_name,
                                :id,
                                :name,
                                {},
                                id: 'charge-type-select' %>
        <div style="padding-bottom:2rem;">
          <% if can?(:create, ChargeType) %>
            <%= link_to 'Or create a new charge type',
                        new_charge_type_path(from_charge: true),
                        class: 'btn btn-primary' %>
          <% end %>
        </div>
      </div>
    </div>
    <%= f.label 'Amount' %>
    <div class="input-group" style="display: flex">
      <%= content_tag :span, '$', class: 'input-group-addon' %>
      <%= f.text_field :amount,
                       as: :string,
                       value:
                         number_to_currency(
                           f.object.amount,
                           unit: '',
                           delimiter: '',
                           html: {
                             id: 'amount'
                           }
                         ) %>
    </div>
    <%= f.label 'Description' %>
    <%= f.text_field :description,
                     as: :text,
                     textarea: '{ font-size:16px; }',
                     html: {
                       id: 'description'
                     } %>
    <%= f.label 'Issuer' %>
    <%= f.collection_select :issuing_participant_id, Participant.scc, :id, :name %>
  </div>
  <div class="form-actions">
    <%= f.button :submit, class: 'btn-primary' %>
    <%= link_to t('.cancel', default: t('helpers.links.cancel')),
                @charge,
                class: 'btn btn-default' %>
  </div>
<% end %>

<!-- Autofill amount and description based on selected charge type -->
<script>
  document
    .getElementById("charge-type-select")
    .addEventListener("change", function () {
      $chargeTypeSelect = $("#charge-type-select");
      $amount = $("#charge_amount");
      console.log($amount.val());
      $description = $("#charge_description");

      const chargeType = $chargeTypeSelect.val();
      $.ajax({
        url: `/charge_types/${chargeType}.json`,
        type: "GET",
      }).done(function (json) {
        $amount.attr("value", json["amount"].replaceAll('"', ""));
        $description.attr("value", json["description"]);
      });
    });
</script>
