<style>
  .step-row {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
  }

  .step-card {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    /* gap: 16px; */
    padding: 10px 14px;
    border-radius: 8px;
  }

  .step-card.approved {
    border: 0.5px solid #9FE1CB;
    background: #F4FBF8;
  }

  .step-card.pending {
    border: 0.5px solid var(--color-border-tertiary);
    background: var(--color-background-primary);
  }

  .step-title {
    font-weight: 500;
    text-decoration: none;
    color: inherit;
  }

  .step-meta {
    font-size: 12px;
    color: #0F6E56;
    margin-top: 2px;
  }

  .step-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .badge-approved {
    font-size: 11px;
    font-weight: 500;
    color: #0F6E56;
    background: #E1F5EE;
    padding: 3px 10px;
    border-radius: 5px;
  }

  .badge-pending {
    font-size: 11px;
    font-weight: 500;
    color: #A32D2D;
    background: #FCEBEB;
    padding: 3px 10px;
    border-radius: 5px;
  }
</style>

<div class="step-row">
  

  <div class="step-card <%= step.approver.present? ? 'approved' : 'pending' %>">
    <div>
      <%= link_to step.title, [@organization, @build_status, step], class: 'step-title' %>
      <% if step.approver.present? %>
        <div class="step-meta">
          Approved by <%= step.approver.send(:cached_name) %>
          <% if step.approved_at.present? %>
            · <%= step.approved_at.strftime('%b %-d at %-l:%M %p') %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="step-actions">
      <% if step.approver.present? %>
        <span class="badge-approved">Approved</span>
      <% else %>
        <span class="badge-pending">Not approved</span>
      <% end %>

      <% if can?(:update, step) %>
        <%= form_with model: [@organization, @build_status, step] do |f| %>
          <%= hidden_field_tag 'update_type', :enabled %>
          <%= hidden_field_tag 'url', request.original_fullpath %>
          <%= f.submit step.is_enabled ? 'Disable' : 'Enable',
                       style: 'font-size: 12px; padding: 0.5em; padding-right: 1em; margin-left: 0.5em'%>
        <% end %>
      <% end %>
    </div>
  </div>
</div>