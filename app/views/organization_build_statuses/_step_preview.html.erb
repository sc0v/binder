<% content_for :head do %>
  <%= stylesheet_link_tag 'organization_build_statuses' %>
<% end %>

<div class="step-row">
  <div class="step-card <%= step.approver.present? ? 'approved' : 'pending' %>">
    <div>
      <%= link_to step.title, [@organization, @build_status, step], class: 'step-title' %>
      <% if step.approver.present? %>
        <div class="step-meta">
          Approved by <%= step.approver.send(:cached_name) %>
          <% if step.approved_at.present? %>
            · <%= step.approved_at.strftime('%b %-d at %-l:%M %p') %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="step-actions">
      <% if step.approver.present? %>
        <span class="badge-approved">Approved</span>
      <% else %>
        <span class="badge-pending">Not approved</span>
      <% end %>

      <% if can?(:update, step) %>
        <%= form_with model: [@organization, @build_status, step] do |f| %>
          <%= hidden_field_tag 'update_type', :enabled %>
          <%= hidden_field_tag 'url', request.original_fullpath %>
          <%= f.button step.is_enabled ? 'Disable' : 'Enable', class: 'step-toggle-btn' %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
