<style>
  .card {
    background: #f9f9f9;
    padding: 2em;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .two-col-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2em;
  }

  .field-label {
    color: #888;
    margin: 0;
    font-size: 0.85em;
  }

  .field-value {
    margin: 0;
  }

  .divider {
    border: none;
    border-top: 1px solid #e0e0e0;
    margin: 0;
  }

  .participant-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6em 0;
    border-bottom: 1px solid #e0e0e0;
  }

  .participant-actions {
    display: flex;
    gap: 0.5em;
    align-items: center;
  }

  .action-buttons {
    display: flex;
    gap: 1em;
    align-items: center;
    margin-top: 1em;
  }
</style>

<div class="content wide">
  <% if can?(:read, @shift) %>
    <%- model_class = Shift -%>
    <h1><%= @shift.shift_type.name %></h1>

    <div class="two-col-grid">
      <%# Shift details %>
      <div class="card">
        <div>
          <p class="field-label"
            ><%= model_class.human_attribute_name(:andrew_id) %></p
          >
          <p class="field-value"><%= @shift.andrew_id.presence || 'N/A' %></p>
        </div>
        <hr class="divider" />
        <div>
          <p class="field-label"
            ><%= model_class.human_attribute_name(:description) %></p
          >
          <p class="field-value"
            ><%= h @shift.description.presence || 'N/A' %></p
          >
        </div>
        <hr class="divider" />
        <div class="two-col-grid">
          <div>
            <p class="field-label"
              ><%= model_class.human_attribute_name(:starts_at) %></p
            >
            <p class="field-value"><%= date_and_time(@shift.starts_at) %></p>
          </div>
          <div>
            <p class="field-label"
              ><%= model_class.human_attribute_name(:ends_at) %></p
            >
            <p class="field-value"><%= date_and_time(@shift.ends_at) %></p>
          </div>
        </div>
        <%# <hr class="divider"/> %>
        <%# <div> %>
        <%# <p class="field-label"><%= model_class.human_attribute_name(:required_number_of_participants) %>
        <%# <p class="field-value"><%= @shift.required_number_of_participants</p> %>
        <%# </div> %>
        <hr class="divider" />
        <div>
          <p class="field-label"
            ><%= model_class.human_attribute_name(:organization) %></p
          >
          <p class="field-value">
            <%= if @shift.organization.blank?
                  'N/A'
                else
                  link_to(@shift.organization.name, @shift.organization)
                end %>
          </p>
        </div>
      </div>
    </div>

    <br />
    <div class="action-buttons">
      <%= link_to t('.back', default: t('helpers.links.back')),
                  shifts_path,
                  class: 'btn btn-default' %>
      <% if can?(:update, @shift) %>
        <%= link_to t('.edit', default: t('helpers.links.edit')),
                    edit_shift_path(@shift),
                    class: 'btn btn-primary' %>
      <% end %>
      <% if can?(:destroy, @shift) %>
        <%= button_to t('.destroy', default: t('helpers.links.destroy')),
                      shift_path(@shift),
                      method: :delete,
                      data: {
                        confirm:
                          t(
                            '.confirm',
                            default: t('helpers.links.confirm', default: 'Are you sure?')
                          )
                      },
                      class: 'btn btn-danger',
                      form: {
                        style: 'display: inline'
                      } %>
      <% end %>
    </div>
  <% else %>
    <h3>Not Authorized!</h3>
  <% end %>
</div>
